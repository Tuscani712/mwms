# Copy this to .env and fill in real values.
# Never commit .env — it's gitignored.

WMS_ENV=development
WMS_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
WMS_DB_URL=sqlite:///./data/wms.db
WMS_JWT_ALGORITHM=HS256
WMS_JWT_EXPIRE_MINUTES=480
WMS_CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765
WMS_SITE_ID_DEFAULT=WHS-001
